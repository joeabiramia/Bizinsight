# Backend
MONGO_URL=mongodb://localhost:27017
MONGO_DB=bizinsight
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bizinsight
UPLOAD_FOLDER=uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend: create frontend/.env with this line if needed
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional only if you later enable OpenAI features
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
# Recommended for testing: gpt-3.5-turbo is the lowest-cost model supported by this app.
