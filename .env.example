# ── Backend ────────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=bizinsight
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bizinsight
UPLOAD_FOLDER=uploads

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:3000,http://127.0.0.1:3000

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
# NEVER commit a real key here — keep real values in your local .env only.
OPENAI_API_KEY=sk-replace-with-your-real-key
OPENAI_MODEL=gpt-4o

# ── SMTP email (required for password reset / digest emails) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=BizInsight AI <your-email@gmail.com>

# ── Auth ───────────────────────────────────────────────────────────────────────
# Change this to a random secret in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Frontend ───────────────────────────────────────────────────────────────────
# Create frontend/.env.local with this line for local dev:
# VITE_API_BASE_URL=http://127.0.0.1:8000
